import csv
import json
import random
from pathlib import Path


BASE_DIR = Path(__file__).resolve().parents[1]

INPUT_FILE = BASE_DIR / "backend"/"data" / "budapest_trees_full.csv"
OUTPUT_FILE = BASE_DIR / "backend"/ "data" / "budapest_trees_sample_10000.json"

SAMPLE_SIZE = 10_000
RANDOM_SEED = 42


KEEP_COLUMNS = [
    "id",
    "supplyId",
    "lat",
    "lon",
    "hungarian_name",
    "latin_name",
    "district",
    "street",
    "streetNumber",
    "height_m",
    "trunk_height_m",
    "trunk_diameter_cm",
    "crown_diameter_m",
    "notable",
    "selected_category_hungarian",
    "selected_category_latin",
]


def clean_value(value):
    if value is None:
        return None

    value = value.strip()

    if value == "":
        return None

    return value


def to_float(value):
    value = clean_value(value)

    if value is None:
        return None

    try:
        return float(value.replace(",", "."))
    except ValueError:
        return None


def load_trees():
    trees = []

    with INPUT_FILE.open("r", encoding="utf-8-sig", newline="") as f:
        reader = csv.DictReader(f)

        for row in reader:
            lat = to_float(row.get("lat"))
            lon = to_float(row.get("lon"))

            if lat is None or lon is None:
                continue

            if not row.get("id"):
                continue

            if not row.get("hungarian_name"):
                continue

            tree = {}

            for col in KEEP_COLUMNS:
                tree[col] = clean_value(row.get(col))

            tree["lat"] = lat
            tree["lon"] = lon

            trees.append(tree)

    return trees


def main():
    trees = load_trees()

    print(f"Loaded usable trees: {len(trees)}")

    random.seed(RANDOM_SEED)

    if len(trees) > SAMPLE_SIZE:
        trees = random.sample(trees, SAMPLE_SIZE)

    OUTPUT_FILE.parent.mkdir(parents=True, exist_ok=True)

    with OUTPUT_FILE.open("w", encoding="utf-8") as f:
        json.dump(trees, f, ensure_ascii=False, indent=2)

    print(f"Saved sample: {len(trees)} trees")
    print(f"Output file: {OUTPUT_FILE}")


if __name__ == "__main__":
    main()